# =============================================
# FastFeast — Environment Variables Template
# =============================================
# HOW TO USE:
# 1. Copy this file:  cp .env.example .env
# 2. Open .env
# 3. Fill in your actual values
# 4. Never commit .env to GitHub
 
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_HOST=localhost
DB_PORT=5432
 
PGADMIN_EMAIL=
PGADMIN_PASSWORD=
 
SMTP_PASSWORD=
 
# ── ALERTING ──────────────────────────────
ALERTING_ENABLED=true 
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SENDER_NAME=FastFeast Pipeline
ALERT_RECIPIENTS=["youremail@gmail.com"]
REPORT_RECIPIENTS=["youremail@gmail.com"]

# ── PII ───────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PII_HASH_PEPPER=